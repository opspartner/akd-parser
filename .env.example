# OpenAI-compatible chat completions endpoint (Ollama, vLLM, LM Studio, llama.cpp, …)
# Must serve POST /chat/completions with vision support.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=qwen3.6-35b
OPENAI_API_KEY=local
# Sampling temperature (default: 0.7). Do NOT use 0.0 with Qwen 3 — causes infinite loops.
# OPENAI_TEMPERATURE=0.7
